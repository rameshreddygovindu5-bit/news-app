# ══════════════════════════════════════════════════════════════
# News Aggregation Platform — Environment Configuration
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values

# ── App ──
DEBUG=true
SECRET_KEY=change-me-in-production

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql+asyncpg://newsadmin:newspass123@localhost:5432/newsagg
DATABASE_URL_SYNC=postgresql://newsadmin:newspass123@localhost:5432/newsagg

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── AI Provider Keys (fill at least one for AI rephrasing) ──
GEMINI_API_KEY=
GEMINI_API_KEY_SECONDARY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── AWS Production DB (for sync) ──
AWS_DB_HOST=
AWS_DB_PORT=5432
AWS_DB_NAME=news_db_fe
AWS_DB_USER=
AWS_DB_PASSWORD=

# ── Social Media (optional) ──
SOCIAL_SITE_URL=https://www.peoples-feedback.com
FB_PAGE_ACCESS_TOKEN=
FB_PAGE_ID=

# ── Scheduler ──
SCHEDULER_ENABLED=true
SCHEDULE_SCRAPE_ENABLED=true
SCHEDULE_AI_ENABLED=true
SCHEDULE_RANKING_ENABLED=true
SCHEDULE_AWS_SYNC_ENABLED=false
SCHEDULE_SOCIAL_ENABLED=false

# ── Scraping ──
ENABLED_SOURCES=
MAX_ARTICLES_PER_SCRAPE=200

# ── CORS ──
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://www.peoples-feedback.com"]
